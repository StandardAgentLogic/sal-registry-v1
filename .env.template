# ============================================================
# SAL Ingestor Agent — Environment Configuration Template
# Copy to .env and fill in values from:
# Supabase Dashboard > Settings > API
# ============================================================

# Project URL (found under "Project URL" in Settings > API)
SUPABASE_URL=https://<your-project-ref>.supabase.co

# Service Role Key — grants full DB access, bypasses RLS
# KEEP SECRET — never expose in client-side code or public repos
SUPABASE_SERVICE_ROLE_KEY=<your-service-role-key>

# Anon/Public Key — safe for read-only public access (optional)
SUPABASE_ANON_KEY=<your-anon-key>

# Firecrawl API Key — for BLS/O*NET data ingestion
FIRECRAWL_API_KEY=<your-firecrawl-api-key>

# Ingestor runtime config
SAL_ENV=production           # production | staging | development
SAL_LOG_LEVEL=info           # debug | info | warn | error
SAL_SYNC_INTERVAL_HOURS=24   # how often to re-sync gov data
